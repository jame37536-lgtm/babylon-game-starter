{
  "name": "babylon-game-starter-vite",
  "version": "1.6.0",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:multiplayer": "nodemon -q --config nodemon.multiplayer.json",
    "dev:multiplayer:once": "go run -C src/server/multiplayer .",
    "dev:fullstack": "concurrently -k -n mp,web -c cyan,green \"npm run dev:multiplayer\" \"npm run dev\"",
    "build": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"eslint.config.js\" \"vite.config.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"eslint.config.js\" \"vite.config.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview",
    "export:playground": "node scripts/generate-playground-json.mjs && node scripts/check-playground-export.mjs",
    "check:playground": "node scripts/check-playground-export.mjs",
    "generate:pwa-assets": "node scripts/generate-pwa-assets.mjs",
    "pwa:test": "npm run build && node scripts/check-pwa.mjs",
    "deploy:prepare": "node src/deployment/scripts/prepare-deployment.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^9.6.2",
    "@babylonjs/gui": "^9.6.2",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/loaders": "^9.6.2",
    "@babylonjs/materials": "^9.6.2",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^9.6.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "babylonjs": "^9.6.2",
    "babylonjs-loaders": "^9.6.2",
    "babylonjs-materials": "^9.6.2",
    "chrome-launcher": "^1.2.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "lighthouse": "^13.3.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.14"
  }
}
